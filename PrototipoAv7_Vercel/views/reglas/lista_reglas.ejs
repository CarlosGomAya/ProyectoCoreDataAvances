<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../css') %>
</head>
<body>
<%- include('../nav') %>

<main class="app-page">
    <div class="app-header">
        <div>
            <h1 class="app-title">Reglas PLD</h1>
            <p class="app-subtitle">Umbrales y criterios de detección de operaciones inusuales o relevantes.</p>
        </div>
        <a href="/reglas/lista?mensaje=En desarrollo" class="btn waves-effect" style="align-self:center">
            Nueva regla
        </a>
    </div>

    <% if (typeof mensaje !== 'undefined' && mensaje) { %>
        <div class="feedback"><%= mensaje %></div>
    <% } %>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:18px">
        <div class="stat">
            <span>Total de reglas</span>
            <strong id="statTotal">—</strong>
        </div>
        <div class="stat">
            <span>Reglas activas</span>
            <strong id="statActivas">—</strong>
        </div>
        <div class="stat">
            <span>Reglas inactivas</span>
            <strong id="statInactivas">—</strong>
        </div>
    </div>

    <section class="panel">
        <table class="striped" style="width:100%">
            <thead>
                <tr>
                    <th style="width:50px">ID</th>
                    <th>Nombre de la regla</th>
                    <th style="width:160px">Umbral de monto</th>
                    <th style="width:150px">Frecuencia máx.</th>
                    <th style="width:100px">Estado</th>
                    <th style="width:110px">Acciones</th>
                </tr>
            </thead>
            <tbody id="reglasBody">
                <tr><td colspan="6" style="color:var(--muted)">Cargando...</td></tr>
            </tbody>
        </table>
    </section>

    <!-- Modal editar regla -->
    <div id="modalEditarRegla" style="display:none;position:fixed;inset:0;background:rgba(36,56,74,0.45);z-index:1000;align-items:center;justify-content:center;">
        <div class="panel" style="width:min(480px,calc(100% - 32px));position:relative;">
            <p style="font-size:16px;font-weight:600;color:var(--azul-oscuro);margin:0 0 18px">Editar regla</p>
            <input type="hidden" id="editIdRegla">
            <div class="form-grid" style="grid-template-columns:1fr;gap:14px;">
                <div>
                    <label>Nombre de la regla</label>
                    <input type="text" id="editNombre" placeholder="Nombre de la regla">
                </div>
                <div>
                    <label>Umbral de monto ($)</label>
                    <input type="number" id="editMonto" placeholder="Ej. 50000" min="0">
                </div>
                <div>
                    <label>Frecuencia máxima (operaciones)</label>
                    <input type="number" id="editFrecuencia" placeholder="Ej. 5" min="1">
                </div>
                <div>
                    <label>Estado</label>
                    <select id="editActiva">
                        <option value="true">Activa</option>
                        <option value="false">Inactiva</option>
                    </select>
                </div>
            </div>
            <div id="editMensaje" style="margin-top:12px;display:none;"></div>
            <div class="form-actions" style="margin-top:18px;">
                <button class="btn" onclick="guardarEdicionRegla()">Guardar cambios</button>
                <button class="btn secondary" onclick="cerrarModalRegla()">Cancelar</button>
            </div>
        </div>
    </div>

    <section class="panel" style="margin-top:18px">
        <h2 style="font-size:16px;font-weight:600;color:var(--azul-oscuro);margin:0 0 12px">Cómo funcionan las reglas</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px">
            <div style="border:1px solid var(--borde);border-radius:8px;padding:14px;background:#f8fbff">
                <p style="font-weight:600;color:var(--azul-oscuro);margin:0 0 6px">Umbral de monto</p>
                <p style="font-size:13px;color:var(--muted);margin:0">
                    Si una operación supera el monto definido, el sistema genera automáticamente una alerta PLD vinculada a esta regla.
                </p>
            </div>
            <div style="border:1px solid var(--borde);border-radius:8px;padding:14px;background:#f8fbff">
                <p style="font-weight:600;color:var(--azul-oscuro);margin:0 0 6px">Frecuencia maxima</p>
                <p style="font-size:13px;color:var(--muted);margin:0">
                    Si un cliente supera el número de operaciones indicado en un periodo determinado, se dispara la alerta por patrón repetitivo.
                </p>
            </div>
            <div style="border:1px solid var(--borde);border-radius:8px;padding:14px;background:#f8fbff">
                <p style="font-weight:600;color:var(--azul-oscuro);margin:0 0 6px">Estado activa / inactiva</p>
                <p style="font-size:13px;color:var(--muted);margin:0">
                    Solo las reglas marcadas como <strong>Activa</strong> se evalúan durante el procesamiento de operaciones nuevas.
                </p>
            </div>
        </div>
    </section>
</main>

<script src="/js/db-ajax.js"></script>
<script>
    window.addEventListener('load', async function() {
        await cargarReglas();
        actualizarStats();
    });

    function actualizarStats() {
        const filas = document.querySelectorAll('#reglasBody tr');
        let activas = 0;
        let total   = 0;
        filas.forEach(function(fila) {
            const badge = fila.querySelector('.badge-ok');
            total++;
            if (badge) activas++;
        });
        const inactivas = total - activas;
        document.getElementById('statTotal').textContent     = total    || 0;
        document.getElementById('statActivas').textContent   = activas  || 0;
        document.getElementById('statInactivas').textContent = inactivas >= 0 ? inactivas : 0;
    }

    function abrirModalRegla(id, nombre, monto, frecuencia, activa) {
        document.getElementById('editIdRegla').value   = id;
        document.getElementById('editNombre').value    = nombre;
        document.getElementById('editMonto').value     = monto !== null ? monto : '';
        document.getElementById('editFrecuencia').value= frecuencia !== null ? frecuencia : '';
        document.getElementById('editActiva').value    = activa ? 'true' : 'false';
        document.getElementById('editMensaje').style.display = 'none';
        document.getElementById('modalEditarRegla').style.display = 'flex';
    }

    function cerrarModalRegla() {
        document.getElementById('modalEditarRegla').style.display = 'none';
    }

    async function guardarEdicionRegla() {
        const id         = document.getElementById('editIdRegla').value;
        const nombre     = document.getElementById('editNombre').value.trim();
        const monto      = document.getElementById('editMonto').value;
        const frecuencia = document.getElementById('editFrecuencia').value;
        const activa     = document.getElementById('editActiva').value === 'true';
        const msgEl      = document.getElementById('editMensaje');

        if (!nombre) {
            msgEl.innerHTML = '<div class="feedback error">El nombre es requerido.</div>';
            msgEl.style.display = 'block';
            return;
        }

        try {
            const resp = await fetch('/reglas/api/editar', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({
                    idRegla:    id,
                    nombre:     nombre,
                    monto:      monto !== '' ? parseFloat(monto) : null,
                    frecuencia: frecuencia !== '' ? parseInt(frecuencia) : null,
                    activa:     activa
                })
            });
            const result = await resp.json();

            if (result.exito) {
                cerrarModalRegla();
                await cargarReglas();
                actualizarStats();
            } else {
                msgEl.innerHTML = '<div class="feedback error">' + (result.error || 'Error al guardar') + '</div>';
                msgEl.style.display = 'block';
            }
        } catch (err) {
            msgEl.innerHTML = '<div class="feedback error">Error: ' + err.message + '</div>';
            msgEl.style.display = 'block';
        }
    }

    document.getElementById('modalEditarRegla').addEventListener('click', function(e) {
        if (e.target === this) cerrarModalRegla();
    });
</script>
</body>
</html>
