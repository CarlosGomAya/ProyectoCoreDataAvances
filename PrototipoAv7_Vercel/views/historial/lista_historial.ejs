<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../css') %>
</head>
<body>
<%- include('../nav') %>

<main class="app-page">
    <div class="app-header">
        <div>
            <h1 class="app-title">Historial</h1>
            <p class="app-subtitle">Registro de eventos y cambios realizados en el sistema.</p>
        </div>
    </div>

    <% if (typeof mensaje !== 'undefined' && mensaje) { %>
        <div class="feedback"><%= mensaje %></div>
    <% } %>

    <section class="panel" style="margin-bottom:16px">
        <form id="filtrosForm" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end">
            <div>
                <label style="display:block;font-size:12px;margin-bottom:4px;color:var(--muted)">Tipo de acción</label>
                <select id="filtroPor" style="min-width:180px">
                    <option value="">Todos</option>
                    <option value="Registro Operacion">Registro Operación</option>
                    <option value="Alerta Generada">Alerta Generada</option>
                    <option value="Alerta Resuelta">Alerta Resuelta</option>
                    <option value="Registro Cliente">Registro Cliente</option>
                    <option value="Login">Login</option>
                    <option value="Sistema">Sistema</option>
                </select>
            </div>
            <div>
                <label style="display:block;font-size:12px;margin-bottom:4px;color:var(--muted)">Fecha inicio</label>
                <input type="date" id="filtroFechaInicio">
            </div>
            <div>
                <label style="display:block;font-size:12px;margin-bottom:4px;color:var(--muted)">Fecha fin</label>
                <input type="date" id="filtroFechaFin">
            </div>
            <div style="display:flex;gap:8px">
                <button type="button" class="btn" onclick="aplicarFiltros()">Filtrar</button>
                <button type="button" class="btn secondary" onclick="limpiarFiltros()">Limpiar</button>
            </div>
        </form>
    </section>

    <section class="panel">
        <table class="striped responsive-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tipo de Acción</th>
                    <th>Descripción</th>
                    <th>Fecha / Hora</th>
                    <th>Usuario</th>
                </tr>
            </thead>
            <tbody id="historialBody">
                <tr>
                    <td colspan="5">Cargando historial...</td>
                </tr>
            </tbody>
        </table>
    </section>
</main>

<script src="/js/db-ajax.js"></script>
<script>
    window.addEventListener('load', function() {
        cargarHistorial();
    });

    function aplicarFiltros() {
        const tipo       = document.getElementById('filtroPor').value;
        const fechaInicio = document.getElementById('filtroFechaInicio').value;
        const fechaFin   = document.getElementById('filtroFechaFin').value;

        const params = new URLSearchParams();
        if (tipo)        params.set('tipoaccion', tipo);
        if (fechaInicio) params.set('fechainicio', fechaInicio);
        if (fechaFin)    params.set('fechafin', fechaFin);

        cargarHistorial('/historial/api/filtrar?' + params.toString());
    }

    function limpiarFiltros() {
        document.getElementById('filtroPor').value = '';
        document.getElementById('filtroFechaInicio').value = '';
        document.getElementById('filtroFechaFin').value = '';
        cargarHistorial();
    }
</script>
</body>
</html>
