<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('./../css.ejs') %>
</head>
<body>
<%- include('./../nav.ejs') %>

<main class="app-page">
    <div class="app-header">
        <div>
            <h1 class="app-title">Operaciones</h1>
            <p class="app-subtitle">Registro y monitoreo inicial de operaciones por contrato y perfil transaccional.</p>
        </div>
        <a href="/operaciones/agregar" class="btn">Registrar</a>
    </div>

    <% if (typeof mensaje !== 'undefined' && mensaje) { %>
        <div class="feedback"><%= mensaje %></div>
    <% } %>

    <section class="panel">
        <table class="striped responsive-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Cliente</th>
                    <th>Contrato</th>
                    <th>Producto</th>
                    <th>Tipo</th>
                    <th>Monto</th>
                    <th>Moneda</th>
                    <th>Fecha</th>
                    <th>Estatus</th>
                </tr>
            </thead>
            <tbody id="operacionesBody">
                <tr>
                    <td colspan="9">Cargando operaciones...</td>
                </tr>
            </tbody>
        </table>
    </section>
</main>

<script src="/js/db-ajax.js"></script>
<script>
    window.addEventListener('load', function() {
        cargarOperaciones();
    });
</script>
</body>
</html>
