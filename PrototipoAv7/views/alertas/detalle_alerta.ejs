<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('./../css.ejs') %>
</head>
<body>
<%- include('./../nav.ejs') %>

<main class="app-page">
    <div class="app-header">
        <div>
            <h1 class="app-title">Alerta #<%= alerta.id_alerta %></h1>
            <p class="app-subtitle">
                <span class="badge-soft <%= alerta.nivel === 'Alto' ? 'badge-danger' : alerta.nivel === 'Medio' ? 'badge-warn' : 'badge-ok' %>"><%= alerta.nivel %></span>
                &nbsp;
                <span class="badge-soft <%= alerta.estatus === 'Resuelta' ? 'badge-ok' : alerta.estatus === 'En revision' ? 'badge-warn' : 'badge-danger' %>"><%= alerta.estatus %></span>
            </p>
        </div>
        <a href="/alertas/lista" class="btn secondary">Volver a alertas</a>
    </div>

    <!-- Datos de la alerta -->
    <section class="panel" style="margin-bottom:18px;">
        <h3 style="margin:0 0 16px;color:var(--azul-oscuro);font-size:16px;">Información de la alerta</h3>
        <div class="form-grid">
            <div>
                <label>Regla disparada</label>
                <div class="readonly-field"><%= alerta.regla || '—' %></div>
            </div>
            <div>
                <label>Fecha</label>
                <div class="readonly-field"><%= alerta.fecha || '—' %></div>
            </div>
            <div>
                <label>Responsable asignado</label>
                <div class="readonly-field"><%= alerta.responsable || '—' %></div>
            </div>
            <% if (cliente) { %>
            <div>
                <label>Cliente</label>
                <div class="readonly-field">
                    <%= cliente.nombre_razon_social %> — RFC: <%= cliente.rfc %>
                    <% if (cliente.es_pep) { %>&nbsp;<span class="badge-soft badge-danger">PEP</span><% } %>
                </div>
            </div>
            <% } %>
        </div>
    </section>

    <!-- Historial de operaciones del cliente -->
    <section class="panel" style="margin-bottom:18px;">
        <h3 style="margin:0 0 16px;color:var(--azul-oscuro);font-size:16px;">Historial de operaciones del cliente</h3>
        <table class="striped responsive-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tipo</th>
                    <th>Monto</th>
                    <th>Moneda</th>
                    <th>Fecha</th>
                </tr>
            </thead>
            <tbody>
                <% if (!operaciones || operaciones.length === 0) { %>
                    <tr><td colspan="5" style="color:var(--muted)">Sin operaciones registradas</td></tr>
                <% } %>
                <% (operaciones || []).forEach(function(o) { %>
                    <tr>
                        <td><%= o.id_operacion %></td>
                        <td><%= o.tipo_operacion || '—' %></td>
                        <td>$<%= Number(o.monto || 0).toLocaleString('es-MX') %></td>
                        <td><%= o.moneda || 'MXN' %></td>
                        <td><%= o.fecha_operacion || '—' %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </section>

    <!-- Formulario de resolucion o dictamen ya registrado -->
    <% if (alerta.estatus !== 'Resuelta') { %>
    <section class="panel">
        <h3 style="margin:0 0 16px;color:var(--azul-oscuro);font-size:16px;">Dictamen y resolución</h3>
        <form action="/alertas/resolver-detalle" method="POST">
            <input type="hidden" name="idAlerta" value="<%= alerta.id_alerta %>">
            <div style="margin-bottom:16px;">
                <label style="display:block;margin-bottom:7px;color:var(--azul-oscuro);font-size:13px;font-weight:600;">Observaciones y dictamen</label>
                <textarea name="resolucion" rows="4" style="width:100%;border:1px solid var(--borde);border-radius:6px;padding:10px 12px;resize:vertical;font-size:14px;background:white;color:var(--texto);"></textarea>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn">Marcar como Resuelta</button>
                <a href="/alertas/lista" class="btn secondary">Cancelar</a>
            </div>
        </form>
    </section>
    <% } else { %>
    <section class="panel">
        <h3 style="margin:0 0 8px;color:var(--azul-oscuro);font-size:16px;">Dictamen registrado</h3>
        <div class="readonly-field" style="min-height:60px;align-items:flex-start;padding-top:10px;">
            <%= alerta.resolucion || 'Sin observaciones registradas' %>
        </div>
    </section>
    <% } %>
</main>
</body>
</html>
