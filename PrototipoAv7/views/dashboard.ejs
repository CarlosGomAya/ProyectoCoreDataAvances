<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('css') %>
    <style>
        .stat-link {
            display: block;
            text-decoration: none;
            color: inherit;
            transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
        }

        .stat-link:hover {
            border-color: var(--azul-principal);
            box-shadow: 0 4px 14px rgba(79, 143, 207, 0.18);
            transform: translateY(-2px);
            color: inherit;
        }

        .stat-link span {
            color: var(--muted);
            font-size: 13px;
        }

        .stat-link strong {
            display: block;
            margin-top: 8px;
            font-size: 32px;
            color: var(--azul-oscuro);
        }

        .stat-link .stat-label-nav {
            display: block;
            margin-top: 10px;
            font-size: 12px;
            font-weight: 600;
            color: var(--azul-principal);
            letter-spacing: 0.3px;
        }

        .dashboard-bottom-grid {
            display: grid;
            grid-template-columns: 1fr minmax(220px, 320px);
            gap: 14px;
            margin-bottom: 18px;
        }

        .panel-title {
            margin: 0 0 14px;
            font-size: 15px;
            font-weight: 600;
            color: var(--azul-oscuro);
        }

        .panel-link {
            display: inline-block;
            margin-top: 12px;
            font-size: 13px;
            color: var(--azul-principal);
        }

        .alerta-row {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid var(--borde);
        }

        .alerta-row:last-child {
            border-bottom: none;
        }

        .alerta-row-info {
            flex: 1;
            font-size: 13px;
            color: var(--texto);
        }

        .alerta-row-fecha {
            font-size: 12px;
            color: var(--muted);
            white-space: nowrap;
        }

        .riesgo-table {
            width: 100%;
            border-collapse: collapse;
        }

        .riesgo-table th {
            text-align: left;
            padding: 6px 8px;
            font-size: 13px;
            color: var(--azul-oscuro);
        }

        .riesgo-table td {
            padding: 10px 8px;
            font-size: 14px;
            border-bottom: 1px solid var(--borde);
        }

        .riesgo-table tr:last-child td {
            border-bottom: none;
        }

        .riesgo-count {
            font-weight: 600;
            color: var(--texto);
        }

        @media (max-width: 700px) {
            .dashboard-bottom-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
<%- include('nav') %>

<main class="app-page">
    <div class="app-header">
        <div>
            <h1 class="app-title">Dashboard</h1>
            <p class="app-subtitle">Resumen operativo para seguimiento de clientes, operaciones y alertas PLD.</p>
        </div>
    </div>

    <section class="stats-grid">
        <a href="/clientes/lista" class="stat stat-link">
            <span>Clientes activos</span>
            <strong id="totalClientes">...</strong>
            <em class="stat-label-nav">Ver expedientes →</em>
        </a>
        <a href="/operaciones/lista" class="stat stat-link">
            <span>Operaciones del mes</span>
            <strong id="totalOperaciones">...</strong>
            <em class="stat-label-nav">Ver operaciones →</em>
        </a>
        <a href="/alertas/lista" class="stat stat-link">
            <span>Alertas pendientes</span>
            <strong id="totalAlertasPendientes">...</strong>
            <em class="stat-label-nav">Revisar alertas →</em>
        </a>
        <a href="/reportes/lista" class="stat stat-link">
            <span>Reportes listos</span>
            <strong id="totalReportesListos">...</strong>
            <em class="stat-label-nav">Ver reportes →</em>
        </a>
    </section>

    <section class="module-grid" aria-label="Otros módulos">
        <a href="/contratos/lista" class="module-link">
            <strong>Contratos</strong>
            <span>Consultar vigencia, saldos y productos.</span>
        </a>
        <a href="/admin/lista" class="module-link">
            <strong>Administración</strong>
            <span>Gestión de usuarios y perfiles del sistema.</span>
        </a>
        <a href="/reglas/lista" class="module-link">
            <strong>Reglas PLD</strong>
            <span>Configurar umbrales y criterios de detección.</span>
        </a>
        <a href="/historial/lista" class="module-link">
            <strong>Historial</strong>
            <span>Registro de eventos y cambios en el sistema.</span>
        </a>
    </section>

    <section class="dashboard-bottom-grid">
        <div class="panel">
            <p class="panel-title">Alertas recientes</p>
            <div id="alertasRecientesContent">
                <p style="color:var(--muted);font-size:13px;">Cargando...</p>
            </div>
            <a href="/alertas/lista" class="panel-link">Ver todas las alertas</a>
        </div>
        <div class="panel">
            <p class="panel-title">Distribución de riesgo</p>
            <table class="riesgo-table">
                <thead>
                    <tr>
                        <th>Nivel</th>
                        <th>Clientes</th>
                    </tr>
                </thead>
                <tbody id="riesgoBody">
                    <tr><td colspan="2" style="color:var(--muted);font-size:13px;">Cargando...</td></tr>
                </tbody>
            </table>
        </div>
    </section>
</main>

<script src="/js/db-ajax.js"></script>
<script>
    window.addEventListener('load', function() {
        cargarDashboard();
    });
</script>
</body>
</html>
